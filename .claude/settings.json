{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-7",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(make *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(node *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(tee *)",
      "Bash(test *)",
      "WebFetch",
      "WebSearch",
      "Bash(bash scripts/deploy.sh)",
      "Bash(bash scripts/deploy.sh *)",
      "mcp__happycake"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(npm publish *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Write(./.env)",
      "Edit(./.env)",
      "Bash(curl * sbc_team_*)",
      "Bash(curl * X-Team-Token*)"
    ]
  },
  "env": {
    "MCP_TIMEOUT": "15000",
    "MAX_MCP_OUTPUT_TOKENS": "50000"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__happycake__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log_mcp.sh"
          }
        ]
      }
    ]
  }
}
