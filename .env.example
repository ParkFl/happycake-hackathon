# HappyCake — environment variables (placeholders only)
# Copy to .env locally and fill in. NEVER commit .env.

# --- MCP Sandbox ---
HAPPYCAKE_MCP_URL=https://www.steppebusinessclub.com/api/mcp
HAPPYCAKE_TEAM_TOKEN=sbc_team_REPLACE_WITH_YOURS

# --- Tunnels (one of) ---
# Free public URL for inbound webhooks to local machine.
# Run: ngrok http 8000  →  copy the https URL into PUBLIC_WEBHOOK_BASE
PUBLIC_WEBHOOK_BASE=https://REPLACE.ngrok-free.app
NGROK_AUTHTOKEN=REPLACE

# --- Telegram bots ---
# Create bots via @BotFather and paste their tokens.
# One bot per agent; here we run two: owner-facing and (optional) sales-trace.
TELEGRAM_BOT_TOKEN_OWNER=REPLACE
TELEGRAM_OWNER_CHAT_ID=REPLACE

# --- Site (Next.js) ---
NEXT_PUBLIC_SITE_URL=https://happycake.us
SITE_PORT=3000

# --- Bot wrappers ---
WEBHOOK_PORT=8000
LOG_DIR=./logs

# --- Claude Code (used by spawned subprocesses) ---
# Claude CLI authenticates via the user's login. No API key in env.
CLAUDE_BIN=claude
