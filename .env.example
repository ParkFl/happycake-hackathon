# HappyCake — environment variables (placeholders only)
# Copy to .env locally and fill in. NEVER commit .env.
#
# Quick sanity: every var below is REQUIRED for the full experience unless
# marked OPTIONAL. The "fresh-clone" Quickstart in README.md references this
# file directly.

# ============================================================
# 1. MCP Sandbox (required) — request your team token in the
#    organizer's Discord. Format: sbc_team_<32 hex chars>.
# ============================================================
HAPPYCAKE_MCP_URL=https://www.steppebusinessclub.com/api/mcp
HAPPYCAKE_TEAM_TOKEN=sbc_team_REPLACE_WITH_YOURS

# ============================================================
# 2. Public tunnel (required for prod chat + WhatsApp/IG webhooks)
#    Vercel /api/chat proxies to your local owner_bot via this URL.
#    Free option: `ngrok http 8000` → copy the https URL.
#    Paste the SAME URL into Vercel as LOCAL_AGENT_URL (env var).
# ============================================================
PUBLIC_WEBHOOK_BASE=https://REPLACE.ngrok-free.app
NGROK_AUTHTOKEN=REPLACE

# When deployed to Vercel, set this var on Vercel (NOT in this file)
# to PUBLIC_WEBHOOK_BASE so the prod /api/chat finds your local agent.
# Locally it's unused. Format: https://abc123.ngrok-free.app (no trailing /).
# LOCAL_AGENT_URL=https://abc123.ngrok-free.app

# Optional shared secret between Vercel and owner_bot. If set on BOTH ends,
# the bot rejects /site-chat / /webhooks/* calls without an `x-site-chat-token`
# header. Recommended for any public ngrok URL.
# SITE_CHAT_TOKEN=any-random-string-32chars

# ============================================================
# 3. Telegram owner bot (required) — create via @BotFather
#    1. /newbot → name + handle → copy token
#    2. Message your bot once
#    3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates
#       → find result[0].message.chat.id (a number) → that's TELEGRAM_OWNER_CHAT_ID
# ============================================================
TELEGRAM_BOT_TOKEN_OWNER=REPLACE
TELEGRAM_OWNER_CHAT_ID=REPLACE

# ============================================================
# 4. Site (Next.js)
# ============================================================
NEXT_PUBLIC_SITE_URL=https://happycake.us
SITE_PORT=3000

# ============================================================
# 5. Bot wrappers
# ============================================================
WEBHOOK_PORT=8000
LOG_DIR=./logs

# OPTIONAL — defaults shown
# SITE_CHAT_TIMEOUT=120          # seconds; chat agent budget per turn
# ESCALATION_DIR=./logs          # where /api/escalation writes JSONL backups
# KITCHEN_TICK_SECONDS=30        # kitchen automator polling interval
# KITCHEN_READY_TIMEOUT_HOURS=4  # mark stale tickets ready after this

# ============================================================
# 6. Claude Code CLI
#    Authenticated via `claude login` (no API key in env).
#    `which claude` should print the path.
# ============================================================
CLAUDE_BIN=claude
